        "pyrunner.Application": {
            "title": "Python 编辑器",
            "icon": "images/icon_{0}.png",
            "type": "iframe",
            "url": "/app/pyrunner/",
            "gatewaySocket": "pyrunner.sock",
            "gatewayPrefix": "/app/pyrunner",
